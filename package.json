{
  "name": "unplugin-iconfont",
  "version": "1.1.2",
  "description": "This plugin is for auto download iconfont symbol js file",
  "main": "./dist/index.cjs",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nuxt": {
      "import": "./dist/nuxt.js",
      "require": "./dist/nuxt.cjs"
    },
    "./vite": {
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./*": "./*"
  },
  "scripts": {
    "prebuild": "rimraf dist/*",
    "build": "tsup",
    "release": "pnpm build && release-it"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imal1/vite-plugin-iconfont.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "vite-plugin",
    "iconfont"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/imal1/vite-plugin-iconfont/issues"
  },
  "homepage": "https://github.com/imal1/vite-plugin-iconfont#readme",
  "devDependencies": {
    "@iconify/tools": "^4.0.4",
    "@nuxt/kit": "^3.12.1",
    "@nuxt/schema": "^3.12.2",
    "@types/node": "^18.11.18",
    "release-it": "^15.6.0",
    "rimraf": "^4.1.2",
    "svg-parser": "^2.0.4",
    "tsup": "^6.5.0",
    "typescript": "^4.9.4",
    "vite": "^4.0.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@9.3.0+sha512.ee7b93e0c2bd11409c6424f92b866f31d3ea1bef5fbe47d3c7500cdc3c9668833d2e55681ad66df5b640c61fa9dc25d546efa54d76d7f8bf54b13614ac293631"
}
